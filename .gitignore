node_modules/
dist/
build/
.tmp/
temp/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# TypeScript
*.tsbuildinfo

# Environment files
.env
.env.*
!.env.example

# -------------------------
# Backend (NestJS)
# -------------------------
/server/dist/
/server/node_modules/
/server/.env
/server/.env.*

# -------------------------
# Frontend (React Web)
# -------------------------
/client/node_modules/
/client/dist/
/client/.env
/client/.env.*

